#!/usr/bin/env bash
# Purpose: dispatch CI-friendly template refresh stages for Forgejo or manual debugging.
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

usage() {
  cat <<'USAGE'
Usage:
  just ci help
  just ci template-refresh
  just ci template-update-lock
  just ci template-build-candidate
  just ci template-test-candidate
  just ci template-promote
  just ci template-cleanup

The scheduled Forgejo path should run:
  just ci template-refresh

Stage subcommands are for logs/debugging. The clean end-to-end path is
template-refresh; it cleans up CI VMs on exit unless NIX_CONFIG_KEEP_CI_VMS=1.
USAGE
}

nix_value() {
  local attr="$1"
  nix --extra-experimental-features 'nix-command flakes' eval --raw --impure \
    --expr "let cfg = import ./data/proxmox-builder.nix; in builtins.toString (cfg.${attr})"
}

template_lock_host=""
template_lock_user=""
template_lock_dir=""

release_template_lock() {
  if [ -n "$template_lock_host" ] && [ -n "$template_lock_user" ] && [ -n "$template_lock_dir" ]; then
    ssh -o BatchMode=yes -o ConnectTimeout=5 "${template_lock_user}@${template_lock_host}" \
      "rm -rf '$template_lock_dir'" >/dev/null 2>&1 || true
  fi
}

acquire_template_lock() {
  local proxmox_host
  local proxmox_user
  local lock_dir
  local owner

  proxmox_host="$(nix_value proxmox.host)"
  proxmox_user="$(nix_value proxmox.user)"
  lock_dir="/var/lock/nix-config-template-ci.lock"
  owner="$(hostname):$$ $(date -u '+%Y-%m-%dT%H:%M:%SZ')"

  if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "${proxmox_user}@${proxmox_host}" "mkdir '$lock_dir' 2>/dev/null"; then
    echo "Template CI lock is already held on Proxmox:" >&2
    ssh -o BatchMode=yes -o ConnectTimeout=5 "${proxmox_user}@${proxmox_host}" "cat '$lock_dir/info' 2>/dev/null || true" >&2
    exit 2
  fi

  ssh -o BatchMode=yes -o ConnectTimeout=5 "${proxmox_user}@${proxmox_host}" "printf '%s\n' '$owner' > '$lock_dir/info'"
  template_lock_host="$proxmox_host"
  template_lock_user="$proxmox_user"
  template_lock_dir="$lock_dir"
}

cleanup_ci_vms() {
  if [ "${NIX_CONFIG_KEEP_CI_VMS:-}" = "1" ]; then
    echo "Keeping CI VMs because NIX_CONFIG_KEEP_CI_VMS=1."
    return 0
  fi

  scripts/ci template-cleanup
}

template_refresh_exit() {
  local status="$1"

  cleanup_ci_vms || true
  release_template_lock
  exit "$status"
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|-h|--help)
    usage
    ;;
  template-update-lock)
    echo "Updating flake.lock."
    nix --extra-experimental-features 'nix-command flakes' flake update "$@"
    ;;
  template-build-candidate)
    echo "Building candidate template."
    NIX_CONFIG_AUTO_APPROVE=1 TEMPLATE_BUILD_SOURCE="${TEMPLATE_BUILD_SOURCE:-ci}" \
      scripts/proxmox-template/build-import candidate "$@"
    ;;
  template-test-candidate)
    scripts/proxmox-template/test-candidate "$@"
    ;;
  template-promote)
    scripts/proxmox-template/promote "$@"
    ;;
  template-cleanup)
    scripts/proxmox-template/cleanup "$@"
    ;;
  template-refresh)
    acquire_template_lock
    trap 'template_refresh_exit "$?"' EXIT
    export NIX_CONFIG_AUTO_APPROVE=1
    export TEMPLATE_BUILD_SOURCE="${TEMPLATE_BUILD_SOURCE:-ci}"
    scripts/ci template-cleanup
    scripts/ci template-update-lock "$@"
    scripts/ci template-build-candidate
    scripts/ci template-test-candidate
    scripts/ci template-promote
    echo "OK: CI template refresh completed."
    ;;
  *)
    echo "Unknown CI command: ${cmd}" >&2
    usage >&2
    exit 2
    ;;
esac
