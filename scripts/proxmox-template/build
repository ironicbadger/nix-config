#!/usr/bin/env bash
# Purpose: run the full break-glass template flow from laptop to tested Proxmox gold.
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$repo_root"

cleanup() {
  if [ "${INFRA_KEEP_TEMPLATE_VMS:-}" = "1" ]; then
    echo "Keeping template build VMs because INFRA_KEEP_TEMPLATE_VMS=1."
    return 0
  fi

  scripts/proxmox-template/cleanup
}

finish() {
  local status="$1"

  trap - EXIT
  cleanup || true
  exit "$status"
}

trap 'finish "$?"' EXIT

TEMPLATE_BUILD_SOURCE="${TEMPLATE_BUILD_SOURCE:-manual}" \
  scripts/proxmox-template/build-import build-temp "$@"
scripts/proxmox-template/test-build-temp
scripts/proxmox-template/promote

echo "OK: proxmox-template build, smoke test, and promotion completed."
