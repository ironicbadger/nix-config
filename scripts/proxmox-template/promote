#!/usr/bin/env bash
# Purpose: promote a smoke-tested build template to current gold and retain the last gold.
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$repo_root"

nix_value() {
  local attr="$1"
  nix --extra-experimental-features 'nix-command flakes' eval --raw --impure \
    --expr "let cfg = import ./data/proxmox-builder.nix; in builtins.toString (cfg.${attr})"
}

proxmox_host="$(nix_value proxmox.host)"
proxmox_user="$(nix_value proxmox.user)"
golden_vmid="$(nix_value template.golden.vmid)"
golden_name="$(nix_value template.golden.name)"
last_vmid="$(nix_value template.last.vmid)"
last_name="$(nix_value template.last.name)"
build_vmid="$(nix_value template.build.vmid)"
build_name="$(nix_value template.build.name)"
destination_storage="$(nix_value template.destinationStorage)"

ssh_common=(
  -o BatchMode=yes
  -o ConnectTimeout=5
  -o ServerAliveInterval=30
  -o ServerAliveCountMax=12
)

echo "Promoting tested build image ${build_name} (${build_vmid}) to ${golden_name} (${golden_vmid})."

ssh "${ssh_common[@]}" "${proxmox_user}@${proxmox_host}" bash -s -- \
  "$build_vmid" "$build_name" "$golden_vmid" "$golden_name" \
  "$last_vmid" "$last_name" "$destination_storage" <<'REMOTE'
set -euo pipefail

build_vmid="$1"
build_name="$2"
golden_vmid="$3"
golden_name="$4"
last_vmid="$5"
last_name="$6"
destination_storage="$7"

build_config="$(qm config "$build_vmid")"
build_actual_name="$(printf '%s\n' "$build_config" | awk -F': ' '$1 == "name" { print $2; exit }')"
build_is_template="$(printf '%s\n' "$build_config" | awk -F': ' '$1 == "template" { print $2; exit }')"
build_description="$(printf '%s\n' "$build_config" | sed -n 's/^description:[[:space:]]*//p' | head -n1)"
promoted_at="$(date -u '+%Y%m%dT%H%M%SZ')"

if [ "$build_actual_name" != "$build_name" ] || [ "$build_is_template" != "1" ]; then
  echo "Build VMID ${build_vmid} is not template '${build_name}'." >&2
  exit 2
fi

case "$build_description" in
  *"tests=passed"*) ;;
  *)
    echo "Build VMID ${build_vmid} has not passed smoke tests." >&2
    echo "Description: ${build_description}" >&2
    exit 2
    ;;
esac

if qm config "$golden_vmid" >/dev/null 2>&1; then
  golden_config="$(qm config "$golden_vmid")"
  existing_name="$(printf '%s\n' "$golden_config" | awk -F': ' '$1 == "name" { print $2; exit }')"
  if [ "$existing_name" != "$golden_name" ]; then
    echo "Golden VMID ${golden_vmid} already exists with name '${existing_name}', not '${golden_name}'." >&2
    echo "Refusing to replace it." >&2
    exit 2
  fi

  if qm config "$last_vmid" >/dev/null 2>&1; then
    existing_name="$(qm config "$last_vmid" | awk -F': ' '$1 == "name" { print $2; exit }')"
    if [ "$existing_name" != "$last_name" ]; then
      echo "Last VMID ${last_vmid} already exists with name '${existing_name}', not '${last_name}'." >&2
      echo "Refusing to replace it." >&2
      exit 2
    fi

    qm stop "$last_vmid" >/dev/null 2>&1 || true
    qm destroy "$last_vmid" --purge 1 --destroy-unreferenced-disks 1
  fi

  golden_description="$(printf '%s\n' "$golden_config" | sed -n 's/^description:[[:space:]]*//p' | head -n1)"
  last_description="${golden_description/target=golden/target=last}"
  last_description="${last_description} superseded=${promoted_at}"

  qm clone "$golden_vmid" "$last_vmid" \
    --name "$last_name" \
    --full 1 \
    --storage "$destination_storage" >/dev/null
  qm set "$last_vmid" --name "$last_name" >/dev/null
  qm set "$last_vmid" --description "$last_description" >/dev/null
  qm template "$last_vmid"

  qm stop "$golden_vmid" >/dev/null 2>&1 || true
  qm destroy "$golden_vmid" --purge 1 --destroy-unreferenced-disks 1
fi

qm clone "$build_vmid" "$golden_vmid" \
  --name "$golden_name" \
  --full 1 \
  --storage "$destination_storage" >/dev/null

description="${build_description/target=build-temp/target=golden} promoted=${promoted_at}"

qm set "$golden_vmid" --name "$golden_name" >/dev/null
qm set "$golden_vmid" --description "$description" >/dev/null
qm template "$golden_vmid"
REMOTE

echo "OK: ${golden_name} (${golden_vmid}) now points at the tested build image."
